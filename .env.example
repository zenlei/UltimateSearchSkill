# ===========================================
# UltimateSearchSkill 环境变量配置
# ===========================================
# 使用方法：复制此文件为 .env 并填入实际值
#   cp .env.example .env

# === grok2api 配置 ===
GROK2API_PORT=8100
# grok2api 管理后台密码（默认是 grok2api；如已在后台修改，这里必须保持一致）
GROK2API_APP_KEY=changeme-to-strong-password
# grok2api 对外 API Key（仅在你显式配置了 app.api_key 时需要）
GROK2API_API_KEY=

# === TavilyProxyManager 配置 ===
TAVILY_PROXY_PORT=8200

# === 搜索脚本配置 ===
GROK_API_URL=http://127.0.0.1:8100
# 调用本地 grok2api 的 Bearer Token。
# 这不是 Grok 官方 API Key，也不是 export_sso.txt 里的 sso token。
# 如果 grok2api 的 app.api_key 为空，这里可以留空。
GROK_API_KEY=
GROK_MODEL=grok-4.1-fast

# === OpenAI Compatible 搜索配置（推荐） ===
# 统一兼容后端入口。已知 URL（如 xAI 官方、OpenRouter）会自动增强搜索；
# 未知 URL 默认只走普通兼容聊天，不做自动探测。
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
# 可选：留空=自动模式；none=强制关闭增强；xai_web_search/openrouter_web=手动覆盖
OPENAI_COMPATIBLE_SEARCH_MODE=

TAVILY_API_URL=http://127.0.0.1:8200
# TavilyProxyManager 的 Master Key（首次启动后从日志获取，脚本调用代理时使用）
TAVILY_MASTER_KEY=

# === FireCrawl 配置（web-fetch 的降级方案）===
# FireCrawl API 地址（默认官方 API，也支持自托管）
FIRECRAWL_API_URL=https://api.firecrawl.dev/v2
# FireCrawl API Key（可选，未配置则跳过 FireCrawl 降级）
# 获取: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=

# ===========================================
# 批量 Key 导入（逗号分隔，用于 import-keys.sh 自动注册到对应服务）
# ===========================================

# Tavily API Keys（逗号分隔，用于导入代理后做轮询）
# 获取: https://www.tavily.com/ 免费 1000次/月
TAVILY_API_KEYS=

# FireCrawl API Keys（逗号分隔）
# 获取: https://www.firecrawl.dev/
FIRECRAWL_API_KEYS=
